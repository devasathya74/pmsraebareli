SECRET_KEY=replace-with-a-secure-secret
SESSION_TIMEOUT_MINUTES=5
MAX_CONTENT_LENGTH=10485760
SCHOOL_NAME=Police Modern School Raebareli

# Development defaults
DATA_BACKEND=local
STORAGE_BACKEND=local

# Local fallback paths
LOCAL_DATA_FILE=data/local_store.json
LOCAL_UPLOAD_DIR=uploads

# Production Firestore
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-service-account.json
FIRESTORE_COLLECTION_PREFIX=pmsr

# Production Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-or-storage-key
SUPABASE_BUCKET=school-files
